<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:orientation="horizontal"
    android:padding="1dp"
    android:background="#E6D78C"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <ImageView
        android:id="@+id/imAnhDaiDien"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="@android:color/holo_blue_light"
        android:contentDescription="Ảnh món ăn"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="vertical"
        android:paddingStart="2dp">

        <TextView
            android:id="@+id/tvTenMonAnh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Món thứ nhất"
            android:textSize="13sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvDonGia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="200000đ"
            android:textSize="10sp"/>

        <TextView
            android:id="@+id/tvMoTa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nội dung mô tả ở đây"
            android:textSize="10sp"/>

    </LinearLayout>

</LinearLayout>