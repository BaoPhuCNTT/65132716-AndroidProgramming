<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:srcCompat="@tools:sample/avatars"
        android:contentDescription="Avatar" />

    <Button
        android:id="@+id/btnTiGia"
        android:layout_width="200dp"
        android:layout_height="70dp"
        android:layout_marginTop="150dp"
        android:onClick="ChuyenTiGia"
        android:text="Tỉ Giá"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnCaKhuc"
        android:layout_width="200dp"
        android:layout_height="70dp"
        android:layout_marginTop="24dp"
        android:onClick="ChuyenCaKhuc"
        android:text="Ca Khúc Cách Mạng"
        app:layout_constraintEnd_toEndOf="@+id/btnTiGia"
        app:layout_constraintStart_toStartOf="@+id/btnTiGia"
        app:layout_constraintTop_toBottomOf="@+id/btnTiGia" />

    <Button
        android:id="@+id/btnDoanhNhanVN"
        android:layout_width="200dp"
        android:layout_height="70dp"
        android:layout_marginTop="24dp"
        android:onClick="ChuyenDoanhNhan"
        android:text="Doanh Nhân Việt Nam"
        app:layout_constraintEnd_toEndOf="@+id/btnCaKhuc"
        app:layout_constraintStart_toStartOf="@+id/btnCaKhuc"
        app:layout_constraintTop_toBottomOf="@+id/btnCaKhuc" />

    <Button
        android:id="@+id/btnGioiThieu"
        android:layout_width="200dp"
        android:layout_height="70dp"
        android:layout_marginTop="24dp"
        android:onClick="ChuyenGioiThieu"
        android:text="Giới thiệu"
        app:layout_constraintEnd_toEndOf="@+id/btnDoanhNhanVN"
        app:layout_constraintStart_toStartOf="@+id/btnDoanhNhanVN"
        app:layout_constraintTop_toBottomOf="@+id/btnDoanhNhanVN" />

</androidx.constraintlayout.widget.ConstraintLayout>